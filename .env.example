# Copy this file to .env and fill in your own values.
# .env is excluded by .gitignore and must never be committed.

# Neon PostgreSQL connection string (a single URL is the simplest form).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Climatiq API key (real-time carbon estimates). Optional: the system falls
# back to standard emission factors if this is absent.
CLIMATIQ_API_KEY=

# Optional location services. Leave blank to disable; the system still works.
OPENCAGE_API_KEY=
ORS_API_KEY=

# ngrok token (only needed for the Colab tunnelling demo, not for Docker).
NGROK_AUTH_TOKEN=

# Endpoints. In Docker Compose these are set by the compose file.
RASA_API_URL=http://localhost:5005/webhooks/rest/webhook
ACTION_ENDPOINT_URL=http://localhost:5055/webhook
